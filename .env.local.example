# Supabase project settings (Project Settings > API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-only, NEVER expose to the client or commit it.
# Used by src/app/api/account/delete/route.ts and the push notification cron
# route (src/app/api/cron/notifications) to bypass RLS. Found in Project
# Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push (VAPID) — generate a pair with `npx web-push generate-vapid-keys`.
# The public key is safe to expose to the client; the private key is not.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# Contact address the push service can use if it needs to reach you about
# this VAPID identity. Any mailto: or https: URL works.
VAPID_SUBJECT=mailto:you@example.com

# Shared secret that authorizes calls to /api/cron/notifications. Vercel
# Cron automatically sends this as `Authorization: Bearer $CRON_SECRET` when
# the env var is set — see vercel.json. Leave unset only for local testing.
CRON_SECRET=your-cron-secret
