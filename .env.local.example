# Supabase project settings (Project Settings > API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-only, NEVER expose to the client or commit it.
# Used only by src/app/api/account/delete/route.ts to delete a user's auth
# account. Found in Project Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
