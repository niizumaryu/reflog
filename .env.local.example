# Supabase project settings (Project Settings > API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-only, NEVER expose to the client or commit it.
# Used by src/app/api/account/delete/route.ts and the push notification cron
# route (src/app/api/cron/notifications) to bypass RLS. Found in Project
# Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push (VAPID) — generate a pair with `npx web-push generate-vapid-keys`.
# The public key is safe to expose to the client; the private key is not.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# Contact address the push service can use if it needs to reach you about
# this VAPID identity. Any mailto: or https: URL works.
VAPID_SUBJECT=mailto:you@example.com

# Shared secret that authorizes calls to /api/cron/notifications. Vercel
# Cron automatically sends this as `Authorization: Bearer $CRON_SECRET` —
# see vercel.json. REQUIRED in every environment, including local dev: the
# route now fails closed (401) whenever this is unset, so set it here even
# for local testing (any random string works locally).
CRON_SECRET=your-cron-secret

# Optional — only needed to run the "authed-*" Playwright projects
# (tests/e2e/authed/**). Leave unset and `npm run test:e2e` still runs the
# full unauthenticated ("public-*") suite; the authed projects are simply
# not registered without both vars. See tests/e2e/README.md.
#
# MUST point at a disposable test account on a DEDICATED test Supabase
# project — never production — because these tests create and delete real
# rows (matches, schedules) under this account. NEXT_PUBLIC_SUPABASE_URL /
# NEXT_PUBLIC_SUPABASE_ANON_KEY above must also point at that same test
# project while running E2E.
E2E_TEST_USER_EMAIL=e2e-test-account@example.com
E2E_TEST_USER_PASSWORD=your-test-account-password

# Not currently used by any code in this repo — no error tracker is wired
# up yet. Documented here as the variable name a future Sentry integration
# should use, so env.example stays the single source of truth for what
# "complete configuration" looks like. See docs/observability.md.
# NEXT_PUBLIC_SENTRY_DSN=
